# Anonymous Studio — Environment Configuration
# Copy this file to .env and fill in your values.
# .env is git-ignored; never commit secrets.

# ── Storage ───────────────────────────────────────────────────────────────────
# Directory used by taipy.core for scenario/DataNode pickle files.
# Must be writable. Defaults to /tmp/anon_studio if unset.
# In production, point this to a directory outside /tmp that is:
#   - not world-readable (chmod 700)
#   - on a disk with enough space for your dataset sizes
#   - cleaned up periodically (DataNodes for completed jobs are deleted on download)
ANON_STORAGE=./data/scenarios

# ── Taipy execution mode ──────────────────────────────────────────────────────
# development  — synchronous, single-process (default, works everywhere)
# standalone   — true parallel worker subprocesses (production)
ANON_MODE=development

# Number of parallel workers (standalone mode only)
ANON_WORKERS=2

# Raw input DataNode backend (modular snap-in):
#   auto   -> development: memory, standalone: mongo
#   memory -> only valid/safe in development mode
#   mongo  -> persisted in Mongo collection (recommended for standalone)
#   pickle -> fallback only; avoid for untrusted environments
ANON_RAW_INPUT_BACKEND=auto

# ── Taipy raw-input Mongo backend (for ANON_RAW_INPUT_BACKEND=mongo) ────────
# You can configure either a single URI or host/db fields.
# URI takes precedence when provided.
# ANON_MONGO_URI=mongodb://localhost:27017/anon_studio
# ANON_MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>
ANON_MONGO_URI=

# Optional explicit fields (used if ANON_MONGO_URI is empty)
# ANON_MONGO_DB=anon_studio
# ANON_MONGO_COLLECTION=raw_input
# ANON_MONGO_HOST=localhost
# ANON_MONGO_PORT=27017
# ANON_MONGO_USER=
# ANON_MONGO_PASSWORD=
# ANON_MONGO_DRIVER=        # e.g. srv
# ANON_MONGO_EXTRA_ARGS=retryWrites=true,w=majority,tls=true
# Batch size for large DataFrame -> Mongo DataNode writes
# (lower to reduce memory spikes, raise to reduce write round-trips)
# ANON_MONGO_WRITE_BATCH=5000

# ── Store backend ─────────────────────────────────────────────────────────────
# Store mode:
#   memory (default) -> always in-memory (ignores MONGODB_URI)
#   mongo            -> require MONGODB_URI and use MongoStore
#   auto             -> legacy behavior (Mongo when MONGODB_URI is set)
ANON_STORE_BACKEND=memory
#
# Set MONGODB_URI only when ANON_STORE_BACKEND=mongo (or auto).
# Requires: pip install pymongo (already in requirements.txt when mongo is used)
#
# Format: mongodb://[user:password@]host[:port]/[database]
# Examples:
#   MONGODB_URI=mongodb://localhost:27017/anon_studio
#   MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>
MONGODB_URI=

# ── spaCy model override ──────────────────────────────────────────────────────
# Leave unset to use auto-detection (en_core_web_lg → md → sm → blank fallback).
# Override only if you need a specific model, e.g. a custom fine-tuned one.
# SPACY_MODEL=en_core_web_lg
# SPACY_MODEL=blank          # force regex-only mode
# Optional path for generated blank fallback model (if no trained model exists).
# ANON_SPACY_BLANK_PATH=./data/spacy/en_blank

# ── Taipy GUI ─────────────────────────────────────────────────────────────────
# Port the development server listens on (default 5000)
# TAIPY_PORT=5000
# Optional host/interface binding for the Taipy server.
# TAIPY_HOST=0.0.0.0

# Set to 1 to enable GUI debug mode (preferred project variable)
# ANON_GUI_DEBUG=0
# Set to 1 to enable GUI hot-reload (preferred project variable)
# ANON_GUI_USE_RELOADER=0
# Backward-compatible aliases (also supported):
# TAIPY_DEBUG=0
# TAIPY_USE_RELOADER=0

# ── Prometheus / Grafana telemetry (optional) ─────────────────────────────────
# Set to a positive integer to enable the Prometheus metrics endpoint.
# Grafana can then scrape http://<host>:<port>/metrics.
# Common choices: 9100 (node-exporter convention), 8000, 9090.
# Leave unset or 0 to disable (default).
# See deploy/grafana/ for a ready-made Prometheus + Grafana stack.
# ANON_METRICS_PORT=9100

# ── Auth0 proxy starter (optional) ───────────────────────────────────────────
# For the oauth2-proxy + nginx starter, see:
#   deploy/auth-proxy/.env.auth-proxy.example
#   deploy/auth-proxy/README.md

# ── Direct Auth0 JWT validation for REST (optional) ─────────────────────────
# Disabled by default for local development.
# Set ANON_AUTH_ENABLED=1 to require Bearer JWTs on rest_main.py endpoints.
# ANON_AUTH_ENABLED=0
# AUTH0_DOMAIN=your-tenant.us.auth0.com
# AUTH0_API_AUDIENCE=https://anonymous-studio-api
# Optional (default RS256):
# ANON_AUTH_JWT_ALGORITHMS=RS256
# Optional space/comma separated scopes required on every request:
# ANON_AUTH_REQUIRED_SCOPES=read:jobs
# Optional comma/space separated exact path exemptions:
# ANON_AUTH_EXEMPT_PATHS=/healthz
# Optional comma/space separated path prefixes:
# ANON_AUTH_EXEMPT_PREFIXES=/public

# ── Attestation digital signatures (Ed25519) ───────────────────────────────
# Optional, but recommended for cryptographic non-repudiation of compliance attestations.
# Provide ONE of:
#   1) base64 raw 32-byte private key seed (recommended)
#   2) PEM private key inline (escape newlines as \n)
#   3) path to PEM/DER private key file
#
# If ANON_ATTEST_REQUIRE_SIGNATURE=1 and no key is configured,
# attestation confirmation is rejected.
#
# ANON_ATTEST_SIGNING_KEY_B64=
# ANON_ATTEST_SIGNING_KEY_PEM=
# ANON_ATTEST_SIGNING_KEY_FILE=
# ANON_ATTEST_SIGNING_KEY_ID=local-ed25519-k1
# ANON_ATTEST_REQUIRE_SIGNATURE=0
