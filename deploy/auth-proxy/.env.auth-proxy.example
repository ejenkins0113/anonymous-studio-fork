# Auth0 tenant
AUTH0_DOMAIN=your-tenant.us.auth0.com
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=

# Use an Auth0 Regular Web Application for oauth2-proxy.
# To get email OTP login, enable Authentication -> Passwordless -> Email
# in Auth0 and attach that connection to the same application via
# Universal Login. oauth2-proxy continues to use standard OIDC.

# oauth2-proxy callback URL (must match Auth0 Allowed Callback URLs)
AUTH_PROXY_REDIRECT_URL=http://localhost:8080/oauth2/callback

# Recommended Auth0 app URLs for local dev:
#   Allowed Callback URLs: http://localhost:8080/oauth2/callback
#   Allowed Logout URLs:   http://localhost:8080
#   Allowed Web Origins:   http://localhost:8080

# 32-byte base64 secret for cookie encryption.
# Generate with:
#   make proxy-cookie-secret
OAUTH2_PROXY_COOKIE_SECRET=

# Local dev listener
AUTH_PROXY_PORT=8080

# Set true only when TLS terminates at this proxy.
AUTH_PROXY_COOKIE_SECURE=false
